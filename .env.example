# ============================================================
# PHOENIX PANEL — Environment Configuration
# Copy to .env and adjust. NEVER commit the real .env.
# ============================================================

# --- Server ---
PHOENIX_HOST=0.0.0.0
PHOENIX_PORT=8080
# public base URL used when generating subscription links
PHOENIX_BASE_URL=https://panel.example.com
# gin mode: debug | release
PHOENIX_MODE=release

# --- Database ---
# driver: sqlite | postgres
PHOENIX_DB_DRIVER=sqlite
# for sqlite: path to file. for postgres: ignored.
PHOENIX_DB_SQLITE_PATH=./data/phoenix.db
# postgres DSN (used when driver=postgres)
PHOENIX_DB_HOST=postgres
PHOENIX_DB_PORT=5432
PHOENIX_DB_USER=phoenix
PHOENIX_DB_PASSWORD=change-me
PHOENIX_DB_NAME=phoenix
PHOENIX_DB_SSLMODE=disable

# --- Security ---
# REQUIRED in production. Generate: openssl rand -hex 32
PHOENIX_JWT_SECRET=please-change-this-to-a-long-random-secret-min-32-chars
# access token lifetime (e.g. 24h, 30m)
PHOENIX_JWT_TTL=24h
# password hashing: argon2id parameters are fixed in code; bcrypt cost:
PHOENIX_BCRYPT_COST=12

# --- Bootstrap admin (created on first run if no admins exist) ---
PHOENIX_ADMIN_USERNAME=admin
PHOENIX_ADMIN_PASSWORD=admin-change-me

# --- Rate limiting ---
# requests per second per client IP for the API
PHOENIX_RATE_RPS=20
PHOENIX_RATE_BURST=40
# stricter limit for /api/admin/login (per IP)
PHOENIX_LOGIN_RATE_RPS=1
PHOENIX_LOGIN_RATE_BURST=5

# --- CORS (comma-separated origins, or * for any) ---
PHOENIX_CORS_ORIGINS=*

# --- Proxy core ---
# default core for new inbounds: xray | sing-box
PHOENIX_DEFAULT_CORE=xray
